# MoQ Results directory
# Ignore everything by default to prevent large model files from being tracked
results/*
# Un-ignore subdirectories so Git can traverse them
!results/*/
# Un-ignore JSON experiment and format map results so they can be synced across machines
!results/**/*.json
!results/*.json

# Python caching and environments
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.conda/

# Build and IDE
moq.egg-info/
build/
dist/
.vscode/
.idea/

# Testing
.pytest_cache/

# OS specific
.DS_Store
moq.egg-info/PKG-INFO
moq.egg-info/SOURCES.txt
